{
    "openapi": "3.0.0",
    "info": {
        "title": "Task Manager API",
        "description": "REST API for creating, viewing, updating, deleting, searching, sorting, and paginating tasks.",
        "version": "1.0.0"
    },
    "paths": {
        "/api/tasks": {
            "get": {
                "tags": [
                    "Tasks"
                ],
                "summary": "Get task list",
                "description": "Returns rows from the tasks table. Supports search, sorting, and pagination.",
                "operationId": "c695515c38113fe023283df8c63f7fc3",
                "parameters": [
                    {
                        "name": "search",
                        "in": "query",
                        "description": "Search text inside the title column.",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "sort",
                        "in": "query",
                        "description": "Sort rows by due_date.",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "due_date"
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Page number for paginated results.",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Task list returned successfully"
                    }
                }
            },
            "post": {
                "tags": [
                    "Tasks"
                ],
                "summary": "Create a new task",
                "description": "Creates a new row in the tasks table using JSON data sent by the client.",
                "operationId": "b4ec6187166148f30a5ea458ed365f5c",
                "requestBody": {
                    "description": "Task data sent by the client.",
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "title",
                                    "due_date",
                                    "status",
                                    "priority",
                                    "category"
                                ],
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "Learn Laravel"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Complete the task manager API",
                                        "nullable": true
                                    },
                                    "due_date": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2026-06-25 18:00:00"
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "not_completed",
                                        "enum": [
                                            "completed",
                                            "not_completed"
                                        ]
                                    },
                                    "priority": {
                                        "type": "string",
                                        "example": "high",
                                        "enum": [
                                            "low",
                                            "medium",
                                            "high"
                                        ]
                                    },
                                    "category": {
                                        "type": "string",
                                        "example": "Work"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Task created successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "id": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Task created successfully"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/tasks/{id}": {
            "get": {
                "tags": [
                    "Tasks"
                ],
                "summary": "Get one task by ID",
                "description": "Returns one row from the tasks table using the ID from the URL.",
                "operationId": "514b6ae515c4bb4f30a5ef54c36ec719",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID of the task row to retrieve.",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Task returned successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "id": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "title": {
                                            "type": "string",
                                            "example": "Learn Laravel"
                                        },
                                        "description": {
                                            "type": "string",
                                            "example": "Complete the task manager API"
                                        },
                                        "due_date": {
                                            "type": "string",
                                            "example": "2026-06-25 18:00:00"
                                        },
                                        "status": {
                                            "type": "string",
                                            "example": "not_completed"
                                        },
                                        "priority": {
                                            "type": "string",
                                            "example": "high"
                                        },
                                        "category": {
                                            "type": "string",
                                            "example": "Work"
                                        },
                                        "created_at": {
                                            "type": "string",
                                            "example": "2026-06-25T08:00:00.000000Z"
                                        },
                                        "updated_at": {
                                            "type": "string",
                                            "example": "2026-06-25T08:00:00.000000Z"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Task not found"
                    }
                }
            },
            "put": {
                "tags": [
                    "Tasks"
                ],
                "summary": "Update a task by ID",
                "description": "Updates one row in the tasks table using the ID from the URL and JSON data sent by the client.",
                "operationId": "f5568faf31c5c4281a77d150679de97c",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID of the task row to update.",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "requestBody": {
                    "description": "Updated task data sent by the client.",
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "title",
                                    "due_date",
                                    "status",
                                    "priority",
                                    "category"
                                ],
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "Learn Laravel API"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Update task endpoint completed",
                                        "nullable": true
                                    },
                                    "due_date": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2026-06-26 18:00:00"
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "completed",
                                        "enum": [
                                            "completed",
                                            "not_completed"
                                        ]
                                    },
                                    "priority": {
                                        "type": "string",
                                        "example": "medium",
                                        "enum": [
                                            "low",
                                            "medium",
                                            "high"
                                        ]
                                    },
                                    "category": {
                                        "type": "string",
                                        "example": "Work"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Task updated successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Task updated successfully"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Task not found"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Tasks"
                ],
                "summary": "Delete a task by ID",
                "description": "Deletes one row from the tasks table using the ID from the URL.",
                "operationId": "f71fe808c8cdb71af15cec604c4c52d9",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID of the task row to delete.",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Task deleted successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Task deleted successfully"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Task not found"
                    }
                }
            }
        }
    },
    "tags": [
        {
            "name": "Tasks",
            "description": "Tasks"
        }
    ]
}